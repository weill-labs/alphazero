# OS/Editor artifacts
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.idea/
.vscode/
*.sublime-*

# Environment/secrets (never commit these)
.env
.env.*
!.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts (add project-specific patterns below)
dist/
build/
*.pyc
__pycache__/
node_modules/
.venv/
venv/

# Local AI agent settings
.claude/settings.local.json
.ntm/
cursor.mcp.json
gemini.mcp.json

# bv (beads viewer) local config and caches
.bv/

# orchestrator scratch (self-play verification/tuning)
.verify_selfplay.py
.tune_selfplay.py

# trained model checkpoints (generated artifact)
checkpoints/

# wandb local run data (generated)
wandb/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/interactions.jsonl
.beads/README.md
.beads/hooks/
.beads/dolt*
.beads/dolt*/.beads/*-wal
.beads/.br_history/
.beads/.br_recovery/
.beads/*.lock
.beads/last-touched

# old beads_rust data (pre-bd migration), kept locally
.beads_br_backup/

# orca agent orchestration clone pool (local, per-project)
.orca/
